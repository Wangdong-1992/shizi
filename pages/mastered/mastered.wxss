page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.page {
  padding: 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 32rpx);
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.nav-back {
  font-size: 48rpx;
  color: #4A90D9;
  padding: 16rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.nav-placeholder {
  width: 80rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: #4A90D9;
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.empty-link {
  font-size: 32rpx;
  color: #4A90D9;
  font-weight: bold;
}

/* 汉字网格 */
.char-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.char-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.char-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.char-pinyin {
  font-size: 24rpx;
  color: #999;
}