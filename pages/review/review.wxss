page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
}

/* ====== 模式切换 ====== */
.mode-tabs {
  display: flex;
  background: white;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  color: white;
  font-weight: bold;
}

/* ====== 连击徽章 ====== */
.combo-area {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.combo-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FECA57 100%);
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 159, 67, 0.4);
}

.combo-badge.super-combo-glow {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9F43 50%, #FECA57 100%);
  box-shadow: 0 0 40rpx rgba(255, 107, 107, 0.6), 0 0 80rpx rgba(255, 159, 67, 0.3);
  animation: superComboPulse 0.8s ease-in-out infinite alternate;
}

.combo-icon {
  font-size: 40rpx;
}

.combo-count {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

/* ====== 进度条 ====== */
.progress-bar {
  margin-bottom: 32rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
}

.progress-track {
  height: 12rpx;
  background: rgba(74, 144, 217, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9 0%, #7AB3ED 100%);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* ====== 卡片入场 ====== */
.card-entrance {
  animation: cardSlideUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ====== 听音选字模式 ====== */
.question-listen {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.listen-hint {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.play-btn {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  border-radius: 50%;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.4);
  border: none;
  transition: transform 0.15s;
}

.play-btn:active {
  transform: scale(0.92);
}

.play-icon {
  font-size: 64rpx;
}

/* ====== 选项 ====== */
.options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.option-item {
  background: #f5f7fa;
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, background 0.3s, border 0.3s;
  border: 4rpx solid transparent;
}

.option-item:active {
  transform: scale(0.94);
}

.option-char {
  font-size: 80rpx;
  font-weight: bold;
  color: #333;
}

.option-item.selected {
  background: rgba(74, 144, 217, 0.2);
  border: 4rpx solid #4A90D9;
}

/* 正确弹跳动画 */
.option-item.correct-pop {
  background: rgba(76, 175, 80, 0.2);
  border: 4rpx solid #4CAF50;
  animation: optionBounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 错误抖动动画 */
.option-item.wrong-shake {
  background: rgba(244, 67, 54, 0.1);
  border: 4rpx solid #f44336;
  animation: optionShake 0.5s ease;
}

/* ====== 反馈卡片 ====== */
.feedback-row {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.feedback-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  animation: feedbackPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.feedback-card.success {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.feedback-card.error {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.feedback-card.info {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.feedback-icon {
  font-size: 36rpx;
}

.feedback-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* ====== 看字说音模式 ====== */
.question-speak {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  text-align: center;
}

.char-display {
  font-size: 280rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  animation: charBreathe 2s ease-in-out infinite;
}

.record-btn {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%);
  border-radius: 60rpx;
  padding: 32rpx 64rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 159, 67, 0.4);
  border: none;
  transition: transform 0.15s;
}

.record-btn:active {
  transform: scale(0.95);
}

.record-btn.recording {
  background: linear-gradient(135deg, #f44336 0%, #e57373 100%);
  animation: recordPulse 1s ease-in-out infinite;
}

.record-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.record-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

/* ====== 完成庆祝遮罩 ====== */
.completion-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: overlayFadeIn 0.3s ease;
}

.completion-card {
  background: white;
  border-radius: 40rpx;
  padding: 64rpx 48rpx 48rpx;
  width: 580rpx;
  text-align: center;
  animation: completionBounceIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.completion-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 16rpx;
  animation: trophySpin 0.8s ease;
}

.completion-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 32rpx;
}

.completion-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E0E0E0;
}

.completion-rate {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.completion-btn {
  background: linear-gradient(135deg, #FF9F43 0%, #FECA57 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(255, 159, 67, 0.4);
}

/* ====== 星星粒子 ====== */
.particle-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 999;
}

.star-particle {
  position: absolute;
  top: -60rpx;
  font-size: 36rpx;
  animation: starFall linear forwards;
}

/* ====== 彩纸粒子 ====== */
.confetti-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1001;
}

.confetti-piece {
  position: absolute;
  top: -40rpx;
  border-radius: 6rpx;
  animation: confettiDrop linear forwards;
}

/* ====== 空状态 / 加载 ====== */
.empty-state {
  text-align: center;
  padding: 100rpx 48rpx;
  font-size: 32rpx;
  color: #999;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #4A90D9;
}

/* ============================================== */
/*  Keyframes                                     */
/* ============================================== */

/* 卡片入场 */
@keyframes cardSlideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 连击弹入 */
@keyframes comboPopIn {
  0%   { opacity: 0; transform: scale(0.3); }
  60%  { opacity: 1; transform: scale(1.15); }
  100% { opacity: 1; transform: scale(1); }
}

/* 超级连击脉冲 */
@keyframes superComboPulse {
  from { transform: scale(1); }
  to   { transform: scale(1.06); }
}

/* 选项弹跳 */
@keyframes optionBounce {
  0%   { transform: scale(1); }
  40%  { transform: scale(1.08); }
  70%  { transform: scale(0.96); }
  100% { transform: scale(1); }
}

/* 选项抖动 */
@keyframes optionShake {
  0%, 100% { transform: translateX(0); }
  15%      { transform: translateX(-12rpx); }
  30%      { transform: translateX(12rpx); }
  45%      { transform: translateX(-10rpx); }
  60%      { transform: translateX(10rpx); }
  75%      { transform: translateX(-6rpx); }
  90%      { transform: translateX(6rpx); }
}

/* 反馈弹入 */
@keyframes feedbackPop {
  from { opacity: 0; transform: scale(0.5) translateY(20rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

/* 汉字呼吸 */
@keyframes charBreathe {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.04); }
}

/* 录音脉冲 */
@keyframes recordPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(244, 67, 54, 0.4); }
  50%      { box-shadow: 0 0 0 24rpx rgba(244, 67, 54, 0); }
}

/* 星星下落 */
@keyframes starFall {
  0%   { opacity: 1; transform: translateY(0) rotate(0deg) scale(1); }
  100% { opacity: 0; transform: translateY(1200rpx) rotate(360deg) scale(0.2); }
}

/* 彩纸下落 */
@keyframes confettiDrop {
  0%   { opacity: 1; transform: translateY(0) rotate(0deg); }
  85%  { opacity: 1; }
  100% { opacity: 0; transform: translateY(1200rpx) rotate(720deg); }
}

/* 遮罩淡入 */
@keyframes overlayFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* 完成卡片弹入 */
@keyframes completionBounceIn {
  0%   { opacity: 0; transform: scale(0.5) translateY(100rpx); }
  70%  { opacity: 1; transform: scale(1.03) translateY(-10rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

/* 奖杯旋转 */
@keyframes trophySpin {
  0%   { transform: rotate(-15deg) scale(0.5); }
  50%  { transform: rotate(10deg) scale(1.1); }
  100% { transform: rotate(0deg) scale(1); }
}
