page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
}

/* 模式切换 */
.mode-tabs {
  display: flex;
  background: white;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  color: white;
  font-weight: bold;
}

/* 进度条 */
.progress-bar {
  margin-bottom: 32rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
}

.progress-track {
  height: 12rpx;
  background: rgba(74, 144, 217, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9 0%, #7AB3ED 100%);
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* 听音选字模式 */
.question-listen {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.listen-hint {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.play-btn {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  border-radius: 50%;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.4);
  border: none;
}

.play-icon {
  font-size: 64rpx;
}

/* 选项 */
.options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.option-item {
  background: #f5f7fa;
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.option-char {
  font-size: 80rpx;
  font-weight: bold;
  color: #333;
}

.option-item.selected {
  background: rgba(74, 144, 217, 0.2);
  border: 4rpx solid #4A90D9;
}

.option-item.correct {
  background: rgba(76, 175, 80, 0.2);
  border: 4rpx solid #4CAF50;
}

.option-item.wrong {
  background: rgba(244, 67, 54, 0.1);
  border: 4rpx solid #f44336;
}

/* 看字说音模式 */
.question-speak {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  text-align: center;
}

.char-display {
  font-size: 280rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.pinyin-display {
  font-size: 56rpx;
  color: #4A90D9;
  margin-bottom: 48rpx;
  font-weight: 500;
}

.record-btn {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%);
  border-radius: 60rpx;
  padding: 32rpx 64rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 159, 67, 0.4);
  border: none;
}

.record-btn.recording {
  background: linear-gradient(135deg, #f44336 0%, #e57373 100%);
}

.record-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.record-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

/* 结果提示 */
.tip-message {
  text-align: center;
  margin-top: 32rpx;
  padding: 24rpx;
  background: white;
  border-radius: 24rpx;
}

.tip-message text {
  font-size: 32rpx;
  color: #333;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #4A90D9;
}