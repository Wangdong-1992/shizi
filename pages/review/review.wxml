<view class="container">
  <!-- 模式切换 -->
  <view class="mode-tabs">
    <text class="tab {{mode === 'listen' ? 'active' : ''}}" bindtap="switchMode" data-mode="listen">听音选字</text>
    <text class="tab {{mode === 'speak' ? 'active' : ''}}" bindtap="switchMode" data-mode="speak">看字说音</text>
  </view>

  <!-- 连击徽章 -->
  <view class="combo-area" wx:if="{{showCombo}}">
    <view class="combo-badge combo-pop-in {{comboLevel === 'super' ? 'super-combo-glow' : ''}}">
      <text class="combo-icon">{{comboIcon}}</text>
      <text class="combo-count">{{comboCount}} 连击！</text>
    </view>
  </view>

  <!-- 进度 -->
  <view class="progress-bar">
    <text class="progress-text">{{currentIndex + 1}} / {{totalCount}}</text>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
    <!-- V2.2: Box等级徽章 -->
    <view class="box-badge box-level-{{currentProgress.box_level || 1}}" wx:if="{{currentProgress}}">
      <text class="box-badge-text">Box {{currentProgress.box_level || 1}}</text>
    </view>
  </view>

  <!-- 题目区域 - 听音选字模式 -->
  <view wx:if="{{mode === 'listen' && currentChar}}" class="question-listen card-entrance">
    <view class="listen-hint">点击播放按钮，听发音后选择正确答案</view>
    <button class="play-btn" bindtap="playAudio">
      <text class="play-icon">🔊</text>
    </button>

    <!-- 选项 -->
    <view class="options-grid">
      <view
        wx:for="{{options}}"
        wx:key="id"
        class="option-item {{selectedId === item.id ? 'selected' : ''}} {{answered ? (item.isCorrect ? 'correct-pop' : (selectedId === item.id ? 'wrong-shake' : '')) : ''}}"
        bindtap="selectOption"
        data-id="{{item.id}}"
      >
        <text class="option-char">{{item.char}}</text>
      </view>
    </view>

    <!-- 反馈卡片 -->
    <view class="feedback-row" wx:if="{{answered}}">
      <view class="feedback-card {{feedbackType}}">
        <text class="feedback-icon">{{feedbackIcon}}</text>
        <text class="feedback-text">{{feedbackMsg}}</text>
      </view>
    </view>
  </view>

  <!-- 题目区域 - 看字说音模式 -->
  <view wx:if="{{mode === 'speak' && currentChar}}" class="question-speak card-entrance">
    <view class="char-display">{{currentChar}}</view>

    <button wx:if="{{!asrProcessing && !showFallbackChoice && !answered}}" class="record-btn {{recording ? 'recording' : ''}}" bindtouchstart="startRecord" bindtouchend="stopRecord">
      <text class="record-icon">{{recording ? '⏸️' : '🎤'}}</text>
      <text class="record-text">{{recording ? '录音中...' : '按住说出发音'}}</text>
    </button>

    <!-- ASR处理中 -->
    <view wx:if="{{asrProcessing}}" class="asr-processing">
      <text class="asr-text">🔍 正在识别...</text>
    </view>

    <!-- ASR失败降级选择题 -->
    <view wx:if="{{showFallbackChoice}}" class="fallback-choice">
      <view class="fallback-hint">🔊 语音识别暂不可用，请选择正确答案</view>
      <view class="options-grid">
        <view wx:for="{{fallbackOptions}}" wx:key="id"
          class="option-item {{selectedId === item.id ? 'selected' : ''}} {{answered ? (item.isCorrect ? 'correct-pop' : (selectedId === item.id ? 'wrong-shake' : '')) : ''}}"
          bindtap="selectFallbackOption" data-id="{{item.id}}">
          <text class="option-char">{{item.char}}</text>
        </view>
      </view>
    </view>

    <!-- 反馈卡片 -->
    <view class="feedback-row" wx:if="{{answered}}">
      <view class="feedback-card {{feedbackType}}">
        <text class="feedback-icon">{{feedbackIcon}}</text>
        <text class="feedback-text">{{feedbackMsg}}</text>
      </view>
    </view>
  </view>

  <!-- V2.2: Box等级变化提示 -->
  <view class="box-toast {{showBoxToast ? 'box-toast-show' : ''}}" wx:if="{{showBoxToast}}">
    <text class="box-toast-text">{{boxChangeToast}}</text>
  </view>

  <!-- V2.2: 状态变化提示 -->
  <view class="status-toast {{showStatusToast ? 'status-toast-show' : ''}}" wx:if="{{showStatusToast}}">
    <text class="status-toast-text">{{statusChangeToast}}</text>
  </view>

  <!-- 粒子层 -->
  <view class="particle-layer" wx:if="{{showStars}}">
    <view wx:for="{{stars}}" wx:key="id" class="star-particle" style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;animation-delay:{{item.delay}}s;transform:rotate({{item.rotate}}deg);">
    </view>
  </view>

  <view class="confetti-layer" wx:if="{{showConfetti}}">
    <view wx:for="{{confetti}}" wx:key="id" class="confetti-piece" style="left:{{item.x}}%;background:{{item.color}};width:{{item.size}}rpx;height:{{item.size}}rpx;animation-delay:{{item.delay}}s;animation-duration:{{item.duration}}s;--wobble:{{item.wobble}}rpx;">
    </view>
  </view>

  <!-- 完成庆祝遮罩 -->
  <view class="completion-overlay" wx:if="{{showCompletion}}">
    <view class="completion-card">
      <text class="completion-emoji">🎉</text>
      <text class="completion-title">复习完成！</text>
      <view class="completion-stats">
        <view class="stat-item">
          <text class="stat-value">{{completionData.correct}}</text>
          <text class="stat-label">正确</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{completionData.total}}</text>
          <text class="stat-label">总题数</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{completionData.maxCombo}}</text>
          <text class="stat-label">最高连击</text>
        </view>
      </view>
      <text class="completion-rate">{{completionData.rate}}% 正确率</text>

      <!-- V2.2: Box分布统计 -->
      <view class="box-distribution" wx:if="{{boxDistribution.box1 + boxDistribution.box2 + boxDistribution.box3 + boxDistribution.box4 + boxDistribution.box5 > 0}}">
        <text class="box-dist-title">本轮Box变化</text>
        <view class="box-dist-row">
          <view class="box-dist-item {{boxDistribution.box1 > 0 ? 'has-change' : ''}}">
            <text class="box-dist-num">{{boxDistribution.box1}}</text>
            <text class="box-dist-label">Box1</text>
          </view>
          <view class="box-dist-item {{boxDistribution.box2 > 0 ? 'has-change' : ''}}">
            <text class="box-dist-num">{{boxDistribution.box2}}</text>
            <text class="box-dist-label">Box2</text>
          </view>
          <view class="box-dist-item {{boxDistribution.box3 > 0 ? 'has-change' : ''}}">
            <text class="box-dist-num">{{boxDistribution.box3}}</text>
            <text class="box-dist-label">Box3</text>
          </view>
          <view class="box-dist-item {{boxDistribution.box4 > 0 ? 'has-change' : ''}}">
            <text class="box-dist-num">{{boxDistribution.box4}}</text>
            <text class="box-dist-label">Box4</text>
          </view>
          <view class="box-dist-item {{boxDistribution.box5 > 0 ? 'has-change' : ''}}">
            <text class="box-dist-num">{{boxDistribution.box5}}</text>
            <text class="box-dist-label">Box5</text>
          </view>
        </view>
      </view>

      <button class="completion-btn" bindtap="restartReview">再来一次</button>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && !currentChar && !showCompletion}}" class="empty-state">
    <text>{{tipMessage || '🎉 今日复习已完成！'}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>
</view>
