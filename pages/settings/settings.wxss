page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
}

.settings-list {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #f5f7fa;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-label {
  font-size: 32rpx;
  color: #333;
}

.settings-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-value {
  font-size: 28rpx;
  color: #999;
}

.settings-avatar-preview {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.settings-avatar-emoji {
  font-size: 48rpx;
}

.settings-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.settings-item.logout {
  justify-content: center;
  border-top: 16rpx solid #f5f7fa;
  border-bottom: none;
}

.logout-text {
  font-size: 32rpx;
  color: #ff4d4f;
}

/* V2.3: 清除数据 — 比退出登录还要"危险"的操作,用警示色 */
.settings-item.logout.danger {
  background: #FFF7E6;
}
.settings-item.logout.danger .logout-text {
  color: #FF9F43;
}

/* ========= 底部弹出弹窗（头像 / 昵称） ========= */

.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
}

.popup-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-sizing: border-box;
}

.popup-sheet.popup-show {
  transform: translateY(0);
}

.popup-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.popup-input {
  width: 100%;
  height: 88rpx;
  background: #F5F7FA;
  border-radius: 44rpx;
  padding: 0 40rpx;
  font-size: 30rpx;
  color: #333;
  text-align: center;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.popup-actions {
  display: flex;
  gap: 24rpx;
}

.popup-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.popup-btn::after {
  border: none;
}

.popup-btn.cancel {
  background: #F5F7FA;
  color: #666;
}

.popup-btn.confirm {
  background: #07C160;
  color: white;
}

/* 微信头像选择按钮（弹窗内） */
.wx-avatar-pick-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx dashed rgba(74, 144, 217, 0.3);
  background: rgba(74, 144, 217, 0.06);
  padding: 0;
  margin: 0 auto 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.wx-avatar-pick-btn::after {
  border: none;
}

.wx-avatar-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.wx-avatar-hint {
  font-size: 20rpx;
  color: #999;
}

.wx-avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ====== R-15: 推送设置 ====== */
.settings-value-small {
  font-size: 24rpx;
  color: #999;
}

.settings-switch {
  transform: scale(0.8);
  margin-left: -8rpx;
}

/* ====== V2.4 宝宝年龄选择 ====== */
.popup-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-top: -8rpx;
  margin-bottom: 24rpx;
}

.age-picker {
  width: 100%;
  margin: 24rpx 0 40rpx;
}

.age-picker-display {
  height: 80rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.age-picker-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90D9;
}

.age-picker-arrow {
  font-size: 24rpx;
  color: #4A90D9;
}
