<view class="container">
  <view class="settings-list">
    <!-- 修改头像 -->
    <view class="settings-item" bindtap="showAvatarSheet">
      <text class="settings-label">修改头像</text>
      <view class="settings-right">
        <image wx:if="{{currentAvatar}}" class="settings-avatar-preview" src="{{currentAvatar}}" mode="aspectFill"/>
        <text wx:else class="settings-avatar-emoji">👶</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- 修改昵称 -->
    <view class="settings-item" bindtap="showNicknameSheet">
      <text class="settings-label">修改昵称</text>
      <view class="settings-right">
        <text class="settings-value">{{currentNickname || '小朋友'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- V2.4: 宝宝年龄 -->
    <view class="settings-item" bindtap="showAgeSheet">
      <text class="settings-label">宝宝年龄</text>
      <view class="settings-right">
        <text class="settings-value">{{currentAge ? currentAge + '岁' : '未设置'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- R-15: 复习提醒推送 -->
    <view class="settings-item">
      <text class="settings-label">📬 复习提醒</text>
      <view class="settings-right">
        <text class="settings-value-small">{{pushSubscribed ? '已开启 (每晚18:00)' : '未开启'}}</text>
        <switch class="settings-switch" checked="{{pushSubscribed}}" color="#07C160" bindchange="togglePushReminder"/>
      </view>
    </view>

    <!-- 关于我们 -->
    <view class="settings-item" bindtap="showAbout">
      <text class="settings-label">关于我们</text>
      <text class="settings-arrow">›</text>
    </view>

    <!-- 退出登录 -->
    <view class="settings-item logout" bindtap="logout">
      <text class="logout-text">退出登录</text>
    </view>

    <!-- V2.3: 清除学习数据(危险操作,带二次确认) -->
    <view class="settings-item logout danger" bindtap="confirmResetData">
      <text class="logout-text">清除学习数据</text>
    </view>
  </view>

  <!-- ========= 修改昵称弹窗 ========= -->
  <view class="popup-mask" wx:if="{{nicknamePopup.show}}" bindtap="closeNicknamePopup"></view>
  <view class="popup-sheet {{nicknamePopup.show ? 'popup-show' : ''}}">
    <text class="popup-title">{{nicknamePopup.title}}</text>
    <input
      class="popup-input"
      type="{{nicknamePopup.inputType}}"
      placeholder="{{nicknamePopup.placeholder}}"
      maxlength="{{nicknamePopup.maxLength}}"
      value="{{nicknamePopup.value}}"
      bindinput="onNicknameChange"
      bindblur="onNicknameChange"
      focus="{{nicknamePopup.show}}"
    />
    <view class="popup-actions">
      <button class="popup-btn cancel" bindtap="closeNicknamePopup">取消</button>
      <button class="popup-btn confirm" bindtap="confirmNickname">确定</button>
    </view>
  </view>

  <!-- ========= V2.4 宝宝年龄选择弹窗 ========= -->
  <view class="popup-mask" wx:if="{{agePopup.show}}" bindtap="closeAgePopup"></view>
  <view class="popup-sheet {{agePopup.show ? 'popup-show' : ''}}">
    <text class="popup-title">选择宝宝年龄</text>
    <text class="popup-hint">宝宝年龄(3-6 岁),用于个性化学习体验</text>
    <picker
      mode="selector"
      range="{{ageRange}}"
      value="{{agePopup.index}}"
      bindchange="onAgePickerChange"
      class="age-picker"
    >
      <view class="age-picker-display">
        <text class="age-picker-text">{{ageRange[agePopup.index]}}</text>
        <text class="age-picker-arrow">▼</text>
      </view>
    </picker>
    <view class="popup-actions">
      <button class="popup-btn cancel" bindtap="closeAgePopup">取消</button>
      <button class="popup-btn confirm" bindtap="confirmAge">确定</button>
    </view>
  </view>

  <!-- ========= 微信头像选择弹窗 ========= -->
  <view class="popup-mask" wx:if="{{avatarPopup.show}}" bindtap="closeAvatarPopup"></view>
  <view class="popup-sheet {{avatarPopup.show ? 'popup-show' : ''}}">
    <text class="popup-title">使用微信头像</text>
    <button class="wx-avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onWxAvatarChoose">
      <image wx:if="{{avatarPopup.tempUrl}}" class="wx-avatar-preview" src="{{avatarPopup.tempUrl}}" mode="aspectFill"/>
      <block wx:else>
        <text class="wx-avatar-icon">📷</text>
        <text class="wx-avatar-hint">点击选择微信头像</text>
      </block>
    </button>
    <view class="popup-actions">
      <button class="popup-btn cancel" bindtap="closeAvatarPopup">取消</button>
      <button class="popup-btn confirm" bindtap="confirmWxAvatar">确定</button>
    </view>
  </view>
</view>
