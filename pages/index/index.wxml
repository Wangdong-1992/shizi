<view class="container">
  <!-- 已登录状态 -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 顶部区域 -->
    <view class="header">
      <view class="user-info">
        <block wx:if="{{userInfo.avatarUrl}}">
          <image class="header-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        </block>
        <block wx:else>
          <view class="avatar">👶</view>
        </block>
        <view class="user-text">
          <text class="greeting">小朋友，你好~</text>
          <text class="nickname">{{userInfo.nickname || '小明'}}</text>
        </view>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item" bindtap="goToMastered">
        <view class="stat-icon blue">📚</view>
        <text class="stat-value">{{stats.mastered_count}}</text>
        <text class="stat-label">已掌握</text>
      </view>
      <view class="stat-item">
        <view class="stat-icon orange">⭐</view>
        <text class="stat-value">{{stats.star_count}}</text>
        <text class="stat-label">星星</text>
      </view>
      <view class="stat-item">
        <view class="stat-icon pink">🌸</view>
        <text class="stat-value">{{stats.flower_count}}</text>
        <text class="stat-label">小红花</text>
      </view>
    </view>

    <!-- 操作区域 -->
    <view class="actions">
      <text class="section-title">开始学习</text>

      <view class="action-card learn" bindtap="startLearn">
        <view class="action-icon">📖</view>
        <view class="action-content">
          <text class="action-title">去学习</text>
          <text class="action-desc">学习新的汉字，认识更多朋友</text>
          <view class="meta-tag">📚 剩余 {{remainingCount}} 字</view>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <view class="action-card review" bindtap="startReview">
        <view class="action-icon">🎯</view>
        <view class="action-content">
          <text class="action-title">去复习</text>
          <text class="action-desc">巩固已学内容，记得更牢固</text>
          <view class="meta-tag">📚 今日待复习 {{pendingReviewCount}} 字</view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- 成就区域 -->
    <view class="achievement-card">
      <view class="achievement-header">
        <text class="achievement-title">🏆 我的成就</text>
        <text class="achievement-badge">{{achievements.unlocked_count || 0}}/{{achievements.total || 0}} 已解锁</text>
      </view>
      <view class="achievement-list">
        <view wx:for="{{achievements.achievements || []}}" wx:key="id" class="achievement-item">
          <view class="achievement-icon {{item.unlocked ? 'unlocked' : 'locked'}}">
            {{item.unlocked ? item.icon : '🔒'}}
          </view>
          <text class="achievement-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 未登录状态：严选风格登录页 -->
  <block wx:else>
    <!-- 全屏背景层 -->
    <view class="login-bg">
      <!-- 漂浮汉字装饰 -->
      <view class="float-char fc1">一</view>
      <view class="float-char fc2">字</view>
      <view class="float-char fc3">学</view>
      <view class="float-char fc4">读</view>
      <view class="float-char fc5">写</view>
      <view class="float-char fc6">认</view>
      <view class="float-char fc7">拼</view>
      <view class="float-char fc8">音</view>
    </view>

    <!-- 主体内容区：居中 Logo + 文案 -->
    <view class="login-body">
      <view class="login-logo-wrap">
        <view class="login-logo">📖</view>
      </view>
      <text class="login-app-name">儿童识字</text>
      <text class="login-slogan">轻松学汉字，快乐每一天</text>
    </view>

    <!-- 底部登录区域（固定在底部） -->
    <view class="login-footer">
      <!-- 手机号授权按钮 -->
      <button
        class="phone-login-btn {{privacyChecked ? '' : 'btn-disabled'}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
      >
        <view class="phone-btn-inner">
          <text class="phone-icon">📱</text>
          <text class="phone-btn-text">微信手机号一键登录</text>
        </view>
      </button>
      <text class="phone-hint">点击按钮授权后自动创建账号</text>

      <!-- 隐私协议 -->
      <view class="privacy-row" bindtap="togglePrivacy">
        <view class="privacy-checkbox {{privacyChecked ? 'checked' : ''}}">
          <text wx:if="{{privacyChecked}}" class="check-icon">✓</text>
        </view>
        <text class="privacy-text">我已阅读并同意</text>
        <text class="privacy-link">《用户协议》</text>
        <text class="privacy-text">和</text>
        <text class="privacy-link">《隐私政策》</text>
      </view>
    </view>
  </block>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <view class="loading-spinner">
      <text class="loading-char">字</text>
    </view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
