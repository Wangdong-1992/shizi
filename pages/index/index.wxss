page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  padding-bottom: 140rpx;
}

/* ====== 入口动效容器 ====== */
.entrance-item {
  opacity: 0;
}

.entrance-slide-up {
  animation: entranceSlideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* ====== 顶部区域 ====== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9F43 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
  border: 6rpx solid white;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 28rpx;
  color: #666;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* ====== 统计卡片 ====== */
.stats-card {
  background: white;
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.stats-card-anim {
  animation-delay: 0.15s;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.stat-icon.blue { background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%); }
.stat-icon.orange { background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%); }
.stat-icon.pink { background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%); }

.stat-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  min-width: 80rpx;
  text-align: center;
  transition: all 0.15s ease;
}

.stat-value.stat-bump {
  transform: scale(1.3);
  color: #4A90D9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ====== V2.2 今日待复习卡片 ====== */
.review-card {
  margin-bottom: 24rpx;
}

.review-card-anim {
  animation-delay: 0.28s;
}

.review-card-inner {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 159, 67, 0.35);
  transition: transform 0.15s;
}

.review-card-inner:active {
  transform: scale(0.97);
}

.review-card-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  flex-shrink: 0;
}

.review-card-content {
  flex: 1;
}

.review-card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}

.review-card-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

.review-card-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ====== 操作区域 ====== */
.actions {
  margin-bottom: 32rpx;
}

.actions-anim {
  animation-delay: 0.4s;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  padding-left: 16rpx;
  border-left: 8rpx solid #4A90D9;
}

.action-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  transition: transform 0.15s;
}

.action-card:active {
  transform: scale(0.97);
}

.action-card.learn { border-left: 8rpx solid #4A90D9; }
.action-card.review { border-left: 8rpx solid #FF9F43; }

.action-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  flex-shrink: 0;
}

.learn .action-icon {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.review .action-icon {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
}

.action-content { flex: 1; }

.action-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.meta-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 600;
}

.action-arrow {
  font-size: 48rpx;
  color: #ccc;
}

/* ====== 成就区域 ====== */
.achievement-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.achievements-anim {
  animation-delay: 0.65s;
}

.achievement-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.achievement-title {
  font-size: 32rpx;
  font-weight: bold;
}

.achievement-badge {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
}

.achievement-badge.badge-pulse {
  animation: badgePulse 2s ease-in-out infinite;
}

.achievement-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  transition: transform 0.3s;
}

.achievement-item.achievement-unlocked-pulse {
  animation: achievementPop 2s ease-in-out infinite;
}

.achievement-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.achievement-icon.unlocked {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 165, 0, 0.4);
}

.achievement-icon.locked {
  background: rgba(74, 144, 217, 0.1);
}

.achievement-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

/* ====== 首页头像图片 ====== */
.header-avatar-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 6rpx solid white;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
}

/* ===================== */
/* 严选风格登录页         */
/* ===================== */

.login-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(160deg, #1a6fc4 0%, #4A90D9 40%, #FF9F43 100%);
  z-index: 0;
  overflow: hidden;
}

.float-char {
  position: absolute;
  color: rgba(255, 255, 255, 0.12);
  font-weight: bold;
  font-size: 80rpx;
  animation: floatUp 8s ease-in-out infinite;
}

.fc1 { left: 5%;  top: 10%; font-size: 120rpx; animation-delay: 0s; }
.fc2 { left: 20%; top: 35%; font-size: 80rpx;  animation-delay: 1s; }
.fc3 { left: 55%; top: 8%;  font-size: 100rpx; animation-delay: 2s; }
.fc4 { left: 75%; top: 25%; font-size: 70rpx;  animation-delay: 0.5s; }
.fc5 { left: 10%; top: 55%; font-size: 90rpx;  animation-delay: 1.5s; }
.fc6 { left: 40%; top: 45%; font-size: 75rpx;  animation-delay: 3s; }
.fc7 { left: 70%; top: 55%; font-size: 85rpx;  animation-delay: 2.5s; }
.fc8 { left: 30%; top: 70%; font-size: 95rpx;  animation-delay: 0.8s; }

@keyframes floatUp {
  0%, 100% { transform: translateY(0px) rotate(-5deg); opacity: 0.12; }
  50%       { transform: translateY(-30rpx) rotate(5deg); opacity: 0.2; }
}

.login-body {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 300rpx;
  z-index: 1;
}

.login-logo-wrap { margin-bottom: 40rpx; }

.login-logo {
  width: 200rpx;
  height: 200rpx;
  background: white;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}

.login-app-name {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.login-slogan {
  font-size: 30rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 4rpx;
}

.login-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  padding: 48rpx 64rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
  box-sizing: border-box;
}

.phone-login-btn {
  width: 100%;
  height: 100rpx;
  background: #07C160;
  border-radius: 50rpx;
  border: none;
  padding: 0;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-login-btn::after { border: none; }

.phone-login-btn.btn-disabled { background: #A0D8B5; }

.phone-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.phone-icon { font-size: 36rpx; }

.phone-btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 4rpx;
}

.phone-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 28rpx;
}

.privacy-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 4rpx;
  padding: 0 16rpx;
}

.privacy-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.privacy-checkbox.checked {
  background: #07C160;
  border-color: #07C160;
}

.check-icon {
  font-size: 22rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}

.privacy-text { font-size: 24rpx; color: #999; }
.privacy-link { font-size: 24rpx; color: #4A90D9; }

/* ====== 加载遮罩 ====== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #FF9F43);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: spin 1.5s ease-in-out infinite;
  margin-bottom: 24rpx;
}

.loading-char {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
}

.loading-text {
  font-size: 28rpx;
  color: #4A90D9;
}

@keyframes spin {
  0%   { transform: rotate(0deg) scale(1); }
  50%  { transform: rotate(180deg) scale(1.1); }
  100% { transform: rotate(360deg) scale(1); }
}

/* ============================================== */
/*  V2.0 首页入场动效 Keyframes                     */
/* ============================================== */

/* 弹性上滑入场 */
@keyframes entranceSlideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 成就徽章脉冲 */
@keyframes badgePulse {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 165, 0, 0.4); }
  50%      { transform: scale(1.05); box-shadow: 0 0 0 12rpx rgba(255, 165, 0, 0); }
}

/* 已解锁成就呼吸 */
@keyframes achievementPop {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.05); }
}
