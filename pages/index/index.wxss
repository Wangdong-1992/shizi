page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  padding-bottom: 140rpx;
}

/* 顶部区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9F43 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
  border: 6rpx solid white;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 28rpx;
  color: #666;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 统计卡片 */
.stats-card {
  background: white;
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  width: 2rpx;
  height: 80rpx;
  background: rgba(74, 144, 217, 0.2);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.stat-icon.blue { background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%); }
.stat-icon.orange { background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%); }
.stat-icon.pink { background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%); }

.stat-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 操作区域 */
.actions {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  padding-left: 16rpx;
  border-left: 8rpx solid #4A90D9;
}

.action-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.action-card.learn {
  border-left: 8rpx solid #4A90D9;
}

.action-card.review {
  border-left: 8rpx solid #FF9F43;
}

.action-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  flex-shrink: 0;
}

.learn .action-icon {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.review .action-icon {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
}

.action-content {
  flex: 1;
}

.action-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.meta-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 600;
}

.action-arrow {
  font-size: 48rpx;
  color: #ccc;
}

/* 成就区域 */
.achievement-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.achievement-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.achievement-title {
  font-size: 32rpx;
  font-weight: bold;
}

.achievement-badge {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
}

.achievement-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
}

.achievement-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.achievement-icon.unlocked {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 165, 0, 0.4);
}

.achievement-icon.locked {
  background: rgba(74, 144, 217, 0.1);
}

.achievement-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.achievement-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.achievement-icon.unlocked {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 165, 0, 0.4);
}

.achievement-icon.locked {
  background: rgba(74, 144, 217, 0.1);
}

.achievement-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #4A90D9;
}

/* 未登录状态 */
.login-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 32rpx;
}

.login-card {
  background: white;
  border-radius: 40rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  width: 100%;
  max-width: 600rpx;
}

.login-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9F43 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 159, 67, 0.4);
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  border-radius: 48rpx;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.login-btn::after {
  border: none;
}