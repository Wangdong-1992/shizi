page {
  background: linear-gradient(180deg, #E8F4FD 0%, #FDF6EC 100%);
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  padding-bottom: 140rpx;
}

/* 顶部区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9F43 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
  border: 6rpx solid white;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 28rpx;
  color: #666;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 统计卡片 */
.stats-card {
  background: white;
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.stat-icon.blue { background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%); }
.stat-icon.orange { background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%); }
.stat-icon.pink { background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%); }

.stat-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 操作区域 */
.actions {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  padding-left: 16rpx;
  border-left: 8rpx solid #4A90D9;
}

.action-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.action-card.learn { border-left: 8rpx solid #4A90D9; }
.action-card.review { border-left: 8rpx solid #FF9F43; }

.action-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  flex-shrink: 0;
}

.learn .action-icon {
  background: linear-gradient(135deg, #4A90D9 0%, #7AB3ED 100%);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.review .action-icon {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB976 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
}

.action-content { flex: 1; }

.action-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.meta-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 600;
}

.action-arrow {
  font-size: 48rpx;
  color: #ccc;
}

/* 成就区域 */
.achievement-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.achievement-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.achievement-title {
  font-size: 32rpx;
  font-weight: bold;
}

.achievement-badge {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
}

.achievement-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
}

.achievement-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.achievement-icon.unlocked {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 165, 0, 0.4);
}

.achievement-icon.locked {
  background: rgba(74, 144, 217, 0.1);
}

.achievement-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

/* 首页头像图片 */
.header-avatar-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 6rpx solid white;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
}

/* ===================== */
/* 严选风格登录页         */
/* ===================== */

/* 全屏背景 */
.login-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(160deg, #1a6fc4 0%, #4A90D9 40%, #FF9F43 100%);
  z-index: 0;
  overflow: hidden;
}

/* 漂浮汉字 */
.float-char {
  position: absolute;
  color: rgba(255, 255, 255, 0.12);
  font-weight: bold;
  font-size: 80rpx;
  animation: floatUp 8s ease-in-out infinite;
}

.fc1 { left: 5%;  top: 10%; font-size: 120rpx; animation-delay: 0s; }
.fc2 { left: 20%; top: 35%; font-size: 80rpx;  animation-delay: 1s; }
.fc3 { left: 55%; top: 8%;  font-size: 100rpx; animation-delay: 2s; }
.fc4 { left: 75%; top: 25%; font-size: 70rpx;  animation-delay: 0.5s; }
.fc5 { left: 10%; top: 55%; font-size: 90rpx;  animation-delay: 1.5s; }
.fc6 { left: 40%; top: 45%; font-size: 75rpx;  animation-delay: 3s; }
.fc7 { left: 70%; top: 55%; font-size: 85rpx;  animation-delay: 2.5s; }
.fc8 { left: 30%; top: 70%; font-size: 95rpx;  animation-delay: 0.8s; }

@keyframes floatUp {
  0%, 100% { transform: translateY(0px) rotate(-5deg); opacity: 0.12; }
  50%       { transform: translateY(-30rpx) rotate(5deg); opacity: 0.2; }
}

/* 主体内容：Logo + Slogan，垂直居中偏上 */
.login-body {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 300rpx; /* 给底部按钮留出空间 */
  z-index: 1;
}

.login-logo-wrap {
  margin-bottom: 40rpx;
}

.login-logo {
  width: 200rpx;
  height: 200rpx;
  background: white;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}

.login-app-name {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.login-slogan {
  font-size: 30rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 4rpx;
}

/* 底部登录区域：固定在底部 */
.login-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  padding: 48rpx 64rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
  box-sizing: border-box;
}

/* 手机号授权按钮（绿色） */
.phone-login-btn {
  width: 100%;
  height: 100rpx;
  background: #07C160;
  border-radius: 50rpx;
  border: none;
  padding: 0;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn.btn-disabled {
  background: #A0D8B5;
}

.phone-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.phone-icon {
  font-size: 36rpx;
}

.phone-btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 4rpx;
}

.phone-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 28rpx;
}

/* 确认登录按钮（保留样式类名，可能有其他地方引用） */
.wx-login-btn {}

/* 隐私协议行 */
.privacy-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 4rpx;
  padding: 0 16rpx;
}

.privacy-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.privacy-checkbox.checked {
  background: #07C160;
  border-color: #07C160;
}

.check-icon {
  font-size: 22rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}

.privacy-text {
  font-size: 24rpx;
  color: #999;
}

.privacy-link {
  font-size: 24rpx;
  color: #4A90D9;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #FF9F43);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: spin 1.5s ease-in-out infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0%   { transform: rotate(0deg) scale(1); }
  50%  { transform: rotate(180deg) scale(1.1); }
  100% { transform: rotate(360deg) scale(1); }
}

.loading-char {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
}

.loading-text {
  font-size: 28rpx;
  color: #4A90D9;
}
