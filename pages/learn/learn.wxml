<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- R-13: 每日新字配额用完 -->
  <view wx:if="{{!loading && dailyQuotaReached}}" class="quota-card">
    <view class="quota-emoji">📚</view>
    <text class="quota-title">今日新字已达标</text>
    <text class="quota-reason">{{dailyQuotaReason}}</text>
    <view class="quota-stats">
      <view class="quota-stat">
        <text class="quota-stat-num">{{dailyNewLearned}}</text>
        <text class="quota-stat-label">今日已学</text>
      </view>
      <view class="quota-stat-divider"></view>
      <view class="quota-stat">
        <text class="quota-stat-num">{{dailyNewLimit}}</text>
        <text class="quota-stat-label">每日上限</text>
      </view>
      <view class="quota-stat-divider"></view>
      <view class="quota-stat">
        <text class="quota-stat-num">{{pendingReview}}</text>
        <text class="quota-stat-label">待复习</text>
      </view>
    </view>
    <view class="quota-actions">
      <view class="quota-btn primary" bindtap="goToReview">
        <text>去复习</text>
      </view>
      <view class="quota-btn secondary" bindtap="goHome">
        <text>返回首页</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && currentChar}}" class="content">

    <!-- ==================== 步骤进度条 ==================== -->
    <view class="step-progress">
      <view class="step-dot {{currentStep >= 1 ? 'active' : ''}} {{stepCompleted[0] ? 'completed' : ''}}">
        <text class="step-num">1</text>
        <text class="step-label">释义</text>
      </view>
      <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="step-dot {{currentStep >= 2 ? 'active' : ''}} {{stepCompleted[1] ? 'completed' : ''}}">
        <text class="step-num">2</text>
        <text class="step-label">再认</text>
      </view>
      <view class="step-line {{currentStep >= 4 ? 'active' : ''}}"></view>
      <view class="step-dot {{currentStep >= 4 ? 'active' : ''}} {{stepCompleted[2] ? 'completed' : ''}}">
        <!-- V2.5.1 删描红后只剩 3 步, 视觉编号 1/2/3. 内部 currentStep 仍用 4 (避免 PRD/数据库 schema 断链) -->
        <text class="step-num">3</text>
        <text class="step-label">跟读</text>
      </view>
    </view>

    <!-- ==================== Step1: 释义 ==================== -->
    <view wx:if="{{currentStep === 1}}" class="step-content step1-content {{cardEntrance ? 'bounce-in' : ''}}">
      <!-- 汉字大卡片 -->
      <view class="char-card {{shaking ? 'shaking' : ''}}">
        <text class="char">{{currentChar}}</text>
        <text class="pinyin">{{pinyin}}</text>
      </view>

      <!-- 听发音按钮 -->
      <view class="btn-row">
        <view class="btn speak-btn" bindtap="playAudio">
          <text>🔊 听发音</text>
        </view>
      </view>

      <!-- 我认识了按钮 -->
      <view class="step1-action">
        <view class="step-complete-btn" bindtap="onStep1Complete">
          <text class="step-complete-icon">👋</text>
          <text class="step-complete-text">我认识了</text>
        </view>
      </view>
    </view>

    <!-- ==================== Step2: 再认 ==================== -->
    <view wx:if="{{currentStep === 2}}" class="step-content step2-content {{cardEntrance ? 'bounce-in' : ''}}">
      <view class="step2-hint">听到发音，选择正确的字</view>

      <!-- 播放按钮 -->
      <view class="step2-play" bindtap="playAudio">
        <text class="step2-play-icon">🔊</text>
        <text class="step2-play-text">听发音</text>
      </view>

      <!-- 3选1选项 -->
      <view class="step2-options" wx:if="{{step2Options.length > 0}}">
        <view wx:for="{{step2Options}}" wx:key="id"
          class="step2-option {{step2Answered && item.isCorrect ? 'correct-pop' : ''}} {{step2Answered && step2SelectedId === item.id && !item.isCorrect ? 'wrong-shake' : ''}} {{step2Answered && step2SelectedId !== item.id ? 'dim' : ''}}"
          bindtap="onStep2Select" data-id="{{item.id}}">
          <text class="step2-option-char">{{item.char}}</text>
        </view>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{step2Options.length === 0 && !step2Answered}}" class="step2-loading">
        <text>加载题目中...</text>
      </view>
    </view>

    <!-- ==================== Step4: 跟读 ==================== -->
    <view wx:if="{{currentStep === 4}}" class="step-content step4-content {{cardEntrance ? 'bounce-in' : ''}}">
      <!-- 汉字展示 -->
      <view class="step4-char-area">
        <text class="step4-char {{shaking ? 'shaking' : ''}}">{{currentChar}}</text>
        <text class="step4-pinyin">{{pinyin}}</text>
      </view>

      <!-- 跟读按钮 + 水波纹 -->
      <view class="record-area" wx:if="{{!showChoiceMode && !asrProcessing && !step4Answered}}">
        <view wx:if="{{isRecording}}" class="ripple-ring ring-1"></view>
        <view wx:if="{{isRecording}}" class="ripple-ring ring-2"></view>
        <view class="record-btn {{isRecording ? 'recording' : ''}}" bindtouchstart="startRecord" bindtouchend="stopRecord">
          <text class="record-icon">{{isRecording ? '⏸️' : '🎤'}}</text>
          <text class="record-text">{{isRecording ? '录音中...' : '按住跟读'}}</text>
        </view>
      </view>

      <!-- ASR处理中 -->
      <view wx:if="{{asrProcessing}}" class="asr-processing">
        <text class="asr-text">🔍 正在识别你的发音...</text>
      </view>

      <!-- ASR失败降级选择题 -->
      <view wx:if="{{showChoiceMode && !step4Answered}}" class="choice-mode">
        <view class="choice-hint">🔊 识别暂不可用，请选择正确答案</view>
        <view class="choice-grid">
          <view wx:for="{{choiceOptions}}" wx:key="id"
            class="choice-item"
            bindtap="selectFallbackOption" data-id="{{item.id}}">
            <text class="choice-char">{{item.char}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== V2.3 小复习 ==================== -->

    <!-- 小复习进行中 -->
    <view wx:if="{{miniReviewActive && !miniReviewCompleted}}" class="mini-review-content">
      <view class="mini-review-header">
        <text class="mini-review-title">📝 小复习</text>
        <text class="mini-review-progress">{{miniReviewIndex + 1}}/{{miniReviewChars.length}}</text>
      </view>

      <view class="mini-review-hint">听到发音，选出正确的字</view>

      <!-- 播放发音按钮 -->
      <view class="mini-review-play" bindtap="playMiniReviewAudio">
        <text class="mini-review-play-icon">🔊</text>
        <text class="mini-review-play-text">再听一次</text>
      </view>

      <!-- 3选1选项 -->
      <view class="mini-review-options" wx:if="{{miniReviewOptions.length > 0}}">
        <view wx:for="{{miniReviewOptions}}" wx:key="id"
          class="step2-option {{miniReviewAnswered && item.isCorrect ? 'correct-pop' : ''}} {{miniReviewAnswered && miniReviewSelectedId === item.id && !item.isCorrect ? 'wrong-shake' : ''}} {{miniReviewAnswered && miniReviewSelectedId !== item.id ? 'dim' : ''}}"
          bindtap="onMiniReviewSelect" data-id="{{item.id}}">
          <text class="step2-option-char">{{item.char}}</text>
        </view>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{miniReviewOptions.length === 0 && !miniReviewAnswered}}" class="step2-loading">
        <text>加载题目中...</text>
      </view>
    </view>

    <!-- 小复习完成摘要 -->
    <view wx:if="{{miniReviewCompleted && miniReviewSummary}}" class="mini-review-summary">
      <view class="summary-card">
        <text class="summary-emoji">{{miniReviewSummary.wrong === 0 ? '🎉' : '💪'}}</text>
        <text class="summary-title">{{miniReviewSummary.wrong === 0 ? '全部正确！' : '小复习完成'}}</text>
        <view class="summary-stats">
          <view class="summary-stat">
            <text class="summary-stat-num correct">{{miniReviewSummary.correct}}</text>
            <text class="summary-stat-label">答对</text>
          </view>
          <view class="summary-stat" wx:if="{{miniReviewSummary.wrong > 0}}">
            <text class="summary-stat-num wrong">{{miniReviewSummary.wrong}}</text>
            <text class="summary-stat-label">需加强</text>
          </view>
        </view>
        <view class="summary-detail" wx:if="{{miniReviewSummary.wrong > 0}}">
          <text class="summary-detail-text">答错的字会在复习中优先出现</text>
        </view>
        <view class="summary-actions">
          <view class="summary-btn primary" bindtap="continueLearning">
            <text>继续学习</text>
          </view>
          <view class="summary-btn secondary" bindtap="goHome">
            <text>返回首页</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ==================== V2.3 渐进式错误提示 ==================== -->
    <view wx:if="{{showProgressiveHint}}" class="progressive-hint hint-level-{{progressiveHintLevel}}">
      <text class="progressive-hint-icon">{{progressiveHintLevel === 3 ? '📖' : '💡'}}</text>
      <text class="progressive-hint-text">{{progressiveHintText}}</text>
      <text wx:if="{{progressiveHintLevel < 3}}" class="progressive-hint-retry">再试一次</text>
    </view>

    <!-- ==================== 反馈卡片 ==================== -->
    <view wx:if="{{feedbackShow}}" class="feedback-card feedback-{{feedbackType}}">
      <text class="feedback-icon">{{feedbackIcon}}</text>
      <text class="feedback-text">{{tipMessage}}</text>
    </view>

    <!-- ==================== 学习完成庆祝 ==================== -->
    <view wx:if="{{learnCompleted}}" class="learn-complete-overlay">
      <view class="learn-complete-card">
        <text class="learn-complete-emoji">🎉</text>
        <text class="learn-complete-title">学会了！</text>
        <text class="learn-complete-char">{{currentChar}}</text>
      </view>
    </view>

    <!-- ==================== 粒子层 ==================== -->
    <view wx:if="{{showStars}}" class="star-layer">
      <view wx:for="{{stars}}" wx:key="id" class="star-particle" style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;animation-delay:{{item.delay}}s;transform:rotate({{item.rotate}}deg);"></view>
    </view>

    <view wx:if="{{showConfetti}}" class="confetti-layer">
      <view wx:for="{{confetti}}" wx:key="id" class="confetti-particle" style="left:{{item.x}}%;background:{{item.color}};width:{{item.size}}rpx;height:{{item.size}}rpx;animation-delay:{{item.delay}}s;animation-duration:{{item.duration}}s;--wobble:{{item.wobble}}rpx;"></view>
    </view>

  </view>

  <view wx:if="{{!loading && !currentChar}}" class="empty">
    <text>{{tipMessage || '暂无内容'}}</text>
  </view>
</view>
