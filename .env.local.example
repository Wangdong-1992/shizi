# .env.local —— 微信小程序云开发环境变量
#
# ⚠️ 这个文件**不 commit**,但 .env.local.example 是模板,告诉你要填什么
# ⚠️ 所有密钥都从 微信公众平台 / 百度智能云 后台拿,不要用代码历史里的老密钥
#
# 用法:
#   1. 复制本文件 → .env.local
#   2. 填上真实密钥值
#   3. 跑 tcb deploy,CloudBase CLI 会自动读 .env.local 注入 cloudbaserc.json 里的 {{env.XXX}}
#
# 腾讯云 CloudBase CLI 加载顺序:.env.local > .env > .env.production/.env.development
# (越往后越优先)

# === 微信小程序 ===
# AppID 是公开的(本就在 app.json 里),不需重置
WX_APPID=wxa2bbfca6b9ef6ebd

# AppSecret 从 微信公众平台 → 开发管理 → 开发设置 → 重置
WX_APPSECRET=your_new_wx_appsecret_here

# === 百度语音 (TTS + ASR) ===
# 从 百度智能云 → 应用列表 → 重置
BAIDU_API_KEY=your_new_baidu_api_key_here
BAIDU_SECRET_KEY=your_new_baidu_secret_key_here
