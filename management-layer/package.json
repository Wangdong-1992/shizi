{
  "name": "geo-management-layer",
  "version": "1.0.0",
  "description": "GEO Platform Management Layer — Node.js + TypeScript + Fastify",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma --migrations-table management_prisma_migrations",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma --migrations-table management_prisma_migrations",
    "prisma:seed": "tsx prisma/seed.ts",
    "worker:import": "tsx src/workers/import.worker.ts",
    "worker:generation": "tsx src/workers/content-generation.worker.ts",
    "worker:scoring": "tsx src/workers/scoring-scheduler.ts",
    "worker:direct-path": "tsx src/workers/direct-path-checker.ts",
    "worker:mention": "tsx src/workers/mention-collector.ts",
    "worker:crawler": "tsx src/workers/crawler-log.worker.ts",
    "worker:scanner": "tsx src/workers/source-scanner.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "openai": "^4.73.0",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
