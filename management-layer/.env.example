# =============================================================================
# GEO Platform — Management Layer Environment Variables
# =============================================================================
# Copy to .env and adjust for your environment.
# ⚠️  SECURITY: Generate your own secure values before deploying!
#
# Run these commands to generate secure values:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# =============================================================================

# PostgreSQL connection string (shared with GEOFlow, same database)
# P0-10 FIX: Use your secure password
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://geo:YOUR_SECURE_PASSWORD_HERE@postgres:5432/geo_platform?schema=public

# JWT shared secret — MUST match GEOFlow's JWT_SECRET
# P0-10 FIX: Generate your own secure JWT secret
# Example: 1551b45ab38c76f3a673276812b649fdbad11ab0315b51ec39011d7223c10f69
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE

# JWT token expiration
JWT_EXPIRES_IN=24h

# JWT issuer — MUST be "geo-management" (validated by GEOFlow's ExternalJwtAuth)
JWT_ISSUER=geo-management

# GEOFlow API base URL (for cross-layer calls via Nginx)
# GeoFlow speaks FastCGI on port 9000, so management MUST call it through
# Nginx (which translates HTTP to FastCGI), not directly.
# In Docker network, use the nginx service name.
GEOFLOW_API_URL=http://nginx/api

# Server configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Logging level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# CORS allowed origins (comma-separated, * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Bcrypt rounds for password hashing
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Redis (BullMQ async task queues)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# OpenAI API (embedding + AI generation)
# -----------------------------------------------------------------------------
# Replace with your actual key. Required for embedding and AI features.
OPENAI_API_KEY=sk-your-key-here
