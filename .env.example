# =============================================================================
# GEO Platform — Environment Variables Template
# =============================================================================
# Copy this file to `.env` and customize values for your environment.
#   cp .env.example .env
#
# ⚠️  SECURITY WARNING: The values below are EXAMPLES ONLY!
#    You MUST generate your own secure random values before deploying.
#    Run the commands below to generate secure values:
#
#    # Generate JWT secret (64+ chars):
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#    # Generate database password (32+ chars):
#    node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
#
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=geo_platform
POSTGRES_USER=geo
# P0-10 FIX: Generate your own secure password
# Example: fdee936aa5b484d60050300f4acd5681
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD_HERE

# -----------------------------------------------------------------------------
# JWT (shared between GEOFlow and Management Layer)
# -----------------------------------------------------------------------------
# P0-10 FIX: Generate your own secure JWT secret (min 64 chars recommended)
# Example: 1551b45ab38c76f3a673276812b649fdbad11ab0315b51ec39011d7223c10f69
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
MANAGEMENT_PORT=3001
FRONTEND_PORT=3000
NGINX_PORT=8080

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Public API URL (used by Frontend Next.js at build time and runtime)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://nginx:8080

# -----------------------------------------------------------------------------
# Frontend Public Configuration (legacy alias)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:8080/api/v1
